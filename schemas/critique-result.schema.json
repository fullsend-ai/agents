{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "critique-result.schema.json",
  "title": "Critique Result",
  "description": "Output schema for the critique agent \u2014 either an approval or revision request for a refinement plan.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "input",
    "verdict",
    "refinement_plan_summary",
    "review_round"
  ],
  "properties": {
    "input": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source",
        "key",
        "level",
        "summary"
      ],
      "properties": {
        "source": {
          "type": "string",
          "enum": [
            "jira",
            "github",
            "gitlab",
            "text"
          ]
        },
        "key": {
          "type": "string"
        },
        "level": {
          "type": "string",
          "enum": [
            "outcome",
            "feature",
            "epic",
            "story",
            "task",
            "issue"
          ]
        },
        "summary": {
          "type": "string"
        }
      }
    },
    "verdict": {
      "type": "string",
      "enum": [
        "approved",
        "revise",
        "needs_input"
      ]
    },
    "question": {
      "type": "object",
      "additionalProperties": false,
      "description": "Required when verdict is needs_input. The ONE question that a human must answer.",
      "properties": {
        "dimension": {
          "type": "string"
        },
        "text": {
          "type": "string"
        },
        "impact": {
          "type": "string"
        },
        "what_refine_assumed": {
          "type": "string"
        }
      },
      "required": [
        "dimension",
        "text",
        "impact"
      ]
    },
    "review_round": {
      "type": "integer",
      "minimum": 1
    },
    "refinement_plan_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "epic_count",
        "story_count",
        "task_count",
        "total_children"
      ],
      "properties": {
        "epic_count": {
          "type": "integer",
          "minimum": 0
        },
        "story_count": {
          "type": "integer",
          "minimum": 0
        },
        "task_count": {
          "type": "integer",
          "minimum": 0
        },
        "total_children": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "assessment": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "coverage": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "score": {
              "type": "number",
              "minimum": 0,
              "maximum": 100
            },
            "reasoning": {
              "type": "string"
            }
          }
        },
        "granularity": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "score": {
              "type": "number",
              "minimum": 0,
              "maximum": 100
            },
            "reasoning": {
              "type": "string"
            }
          }
        },
        "dependency_coherence": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "score": {
              "type": "number",
              "minimum": 0,
              "maximum": 100
            },
            "reasoning": {
              "type": "string"
            }
          }
        },
        "implementability": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "score": {
              "type": "number",
              "minimum": 0,
              "maximum": 100
            },
            "reasoning": {
              "type": "string"
            }
          }
        },
        "scope_accuracy": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "score": {
              "type": "number",
              "minimum": 0,
              "maximum": 100
            },
            "reasoning": {
              "type": "string"
            }
          }
        },
        "assumption_grounding": {
          "type": "object",
          "additionalProperties": false,
          "description": "Are the plan's architectural decisions backed by exploration context or unverified guesses?",
          "properties": {
            "score": {
              "type": "number",
              "minimum": 0,
              "maximum": 100
            },
            "reasoning": {
              "type": "string"
            }
          }
        },
        "program_grounding": {
          "type": "object",
          "description": "When ORG_KNOWLEDGE has real packed content (not the no-pack stub): ownership, Definition of Done, and anti-slop writing standards. Omit when no pack is available.",
          "properties": {
            "score": {
              "type": "number",
              "minimum": 0,
              "maximum": 100
            },
            "reasoning": {
              "type": "string"
            }
          }
        },
        "description_clarity": {
          "type": "object",
          "additionalProperties": false,
          "description": "Does the proposed_description use the correct format for its level and avoid content duplication?",
          "properties": {
            "score": {
              "type": "number",
              "minimum": 0,
              "maximum": 100
            },
            "reasoning": {
              "type": "string"
            }
          }
        },
        "project_routing": {
          "type": "object",
          "additionalProperties": false,
          "description": "Do target_project assignments match routing context? Only scored when routing context is present.",
          "properties": {
            "score": {
              "type": "number",
              "minimum": 0,
              "maximum": 100
            },
            "reasoning": {
              "type": "string"
            }
          }
        },
        "overall": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        }
      }
    },
    "revisions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "type",
          "target",
          "reasoning"
        ],
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "remove",
              "merge",
              "split",
              "revise",
              "add"
            ]
          },
          "target": {
            "type": "string",
            "description": "Title of the child item this revision targets, or 'plan' for plan-level feedback"
          },
          "reasoning": {
            "type": "string"
          },
          "suggestion": {
            "type": "string"
          }
        }
      }
    },
    "comment": {
      "type": "string",
      "maxLength": 4000
    },
    "summary": {
      "type": "string",
      "maxLength": 2000
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "verdict": {
            "const": "revise"
          }
        }
      },
      "then": {
        "required": [
          "input",
          "verdict",
          "refinement_plan_summary",
          "review_round",
          "revisions",
          "comment",
          "summary"
        ],
        "properties": {
          "revisions": {
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "verdict": {
            "const": "needs_input"
          }
        }
      },
      "then": {
        "required": [
          "input",
          "verdict",
          "refinement_plan_summary",
          "review_round",
          "question",
          "comment",
          "summary"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "verdict": {
            "const": "approved"
          }
        }
      },
      "then": {
        "required": [
          "input",
          "verdict",
          "refinement_plan_summary",
          "review_round",
          "assessment",
          "comment",
          "summary"
        ]
      }
    }
  ]
}
